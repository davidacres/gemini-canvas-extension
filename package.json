{
  "name": "gemini-canvas-extension",
  "displayName": "Gemini Canvas Extension",
  "description": "Scaffold for a Gemini-Canvas-style VS Code custom editor workspace.",
  "version": "0.0.1",
  "publisher": "davidacres",
  "license": "UNLICENSED",
  "engines": {
    "vscode": "^1.97.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "geminiCanvas.showWelcome",
        "title": "Gemini Canvas: Show Welcome"
      }
    ]
  },
  "scripts": {
    "clean": "rimraf dist media/webview .vscode-test",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "typecheck": "npm run typecheck:extension && npm run typecheck:webview",
    "typecheck:extension": "tsc -p tsconfig.extension.json --noEmit",
    "typecheck:webview": "tsc -p tsconfig.webview.json --noEmit",
    "compile:extension": "tsc -p tsconfig.extension.json",
    "build:webview": "vite build",
    "build": "npm run clean && npm run compile:extension && npm run build:webview",
    "test:unit": "vitest run",
    "test:integration": "npm run compile:extension && node ./scripts/runIntegrationTests.mjs",
    "test": "npm run test:unit && npm run test:integration"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/vscode": "^1.97.0",
    "@vscode/test-electron": "^2.4.1",
    "eslint": "^9.21.0",
    "globals": "^16.0.0",
    "mocha": "^11.1.0",
    "prettier": "^3.5.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.25.0",
    "vite": "^6.2.1",
    "vitest": "^3.0.7"
  }
}