name: CI

"on":
  workflow_dispatch:
  pull_request:
    branches:
      - main
      - plan-base
  push:
    branches:
      - main
      - plan-base
      - phase/**
      - copilot/**
      - chore/**

permissions:
  contents: read

concurrency:
  group: ci-${{ github.workflow }}-${{ github.ref }}
  cancel-in-progress: true

jobs:
  quality:
    name: Quality (${{ matrix.os }})
    runs-on: ${{ matrix.os }}
    strategy:
      fail-fast: false
      matrix:
        os: [ubuntu-latest]

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Detect Node project
        id: detect
        shell: bash
        run: |
          if [[ -f package.json ]]; then
            echo "has_package=true" >> "$GITHUB_OUTPUT"
          else
            echo "has_package=false" >> "$GITHUB_OUTPUT"
          fi

      - name: Setup Node
        if: steps.detect.outputs.has_package == 'true'
        uses: actions/setup-node@v4
        with:
          node-version: 22
          cache: npm

      - name: Install dependencies
        if: steps.detect.outputs.has_package == 'true'
        shell: bash
        run: npm ci

      - name: Run script checks
        if: steps.detect.outputs.has_package == 'true'
        shell: bash
        run: |
          node - <<'NODE'
          const fs = require('fs');
          const pkg = JSON.parse(fs.readFileSync('package.json', 'utf8'));
          const scripts = pkg.scripts || {};
          const order = ['lint', 'typecheck', 'test', 'build'];
          const { spawnSync } = require('child_process');

          for (const name of order) {
            if (!scripts[name]) {
              console.log(`skip: npm run ${name} (script not defined)`);
              continue;
            }
            console.log(`run: npm run ${name}`);
            const r = spawnSync('npm', ['run', name], { stdio: 'inherit', shell: process.platform === 'win32' });
            if (r.status !== 0) {
              process.exit(r.status || 1);
            }
          }
          NODE

      - name: No-op (no package yet)
        if: steps.detect.outputs.has_package != 'true'
        run: echo "No package.json found yet; CI script checks skipped."
