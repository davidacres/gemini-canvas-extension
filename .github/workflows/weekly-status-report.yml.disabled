name: Weekly status report

"on":
  workflow_dispatch:
  schedule:
    - cron: "30 12 * * 1"

permissions:
  contents: read
  issues: write

jobs:
  report:
    runs-on: ubuntu-latest
    steps:
      - name: Publish weekly status issue
        uses: actions/github-script@v7
        with:
          github-token: ${{ secrets.PLAN_SYNC_TOKEN || github.token }}
          script: |
            const now = new Date();
            const isoDate = now.toISOString().slice(0, 10);
            const title = `Weekly status report (${isoDate})`;
            const reportLabel = 'weekly-report';

            async function ensureLabel(name, color, description) {
              try {
                await github.rest.issues.createLabel({
                  owner: context.repo.owner,
                  repo: context.repo.repo,
                  name,
                  color,
                  description,
                });
              } catch (e) {
                if (e?.status !== 422) throw e;
              }
            }

            await ensureLabel(reportLabel, '5319e7', 'Automated weekly status report');
            await ensureLabel('plan-sync', '0e8a16', 'Managed by plan-sync workflow');

            const openIssues = await github.paginate(github.rest.issues.listForRepo, {
              owner: context.repo.owner,
              repo: context.repo.repo,
              state: 'open',
              labels: 'plan-sync',
              per_page: 100,
            });

            const closedIssues = await github.paginate(github.rest.issues.listForRepo, {
              owner: context.repo.owner,
              repo: context.repo.repo,
              state: 'closed',
              labels: 'plan-sync',
              per_page: 100,
            });

            function issueLine(i) {
              return `- #${i.number} ${i.title}`;
            }

            const body = [
              'Automated report for milestone tracking.',
              '',
              `- Open milestones: **${openIssues.length}**`,
              `- Closed milestones: **${closedIssues.length}**`,
              '',
              '## Open milestone issues',
              ...(openIssues.length ? openIssues.map(issueLine) : ['- None']),
              '',
              '## Recently closed milestone issues',
              ...(closedIssues.slice(0, 10).map(issueLine).length ? closedIssues.slice(0, 10).map(issueLine) : ['- None']),
              '',
              '_Generated by `.github/workflows/weekly-status-report.yml`._',
            ].join('\n');

            const existing = await github.paginate(github.rest.issues.listForRepo, {
              owner: context.repo.owner,
              repo: context.repo.repo,
              state: 'open',
              labels: reportLabel,
              per_page: 100,
            });

            const thisWeek = existing.find(i => i.title === title && !i.pull_request);
            if (thisWeek) {
              await github.rest.issues.update({
                owner: context.repo.owner,
                repo: context.repo.repo,
                issue_number: thisWeek.number,
                body,
              });
              core.info(`Updated weekly report issue #${thisWeek.number}`);
            } else {
              const created = await github.rest.issues.create({
                owner: context.repo.owner,
                repo: context.repo.repo,
                title,
                body,
                labels: [reportLabel],
              });
              core.info(`Created weekly report issue #${created.data.number}`);
            }
